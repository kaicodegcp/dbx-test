{
  "description": "IAM Policies required for Databricks Serverless workspace deployment",
  "policies": [
    {
      "policy_name": "workspace-root-s3-bucket-policy",
      "description": "S3 bucket policy granting Databricks access to the workspace root storage bucket. Uses PrincipalTag-based condition for Databricks account scoping. Includes a Deny statement to prevent DBFS from accessing Unity Catalog metastore paths.",
      "type": "s3-bucket-policy",
      "statements": [
        {
          "sid": "GrantDatabricksAccess",
          "effect": "Allow",
          "actions": [
            "s3:GetObject",
            "s3:GetObjectVersion",
            "s3:PutObject",
            "s3:DeleteObject",
            "s3:ListBucket",
            "s3:GetBucketLocation"
          ],
          "principal": "arn:aws:iam::${databricks_aws_account_id}:root",
          "resources": [
            "${workspace_root_bucket_arn}/*",
            "${workspace_root_bucket_arn}"
          ],
          "condition": "aws:PrincipalTag/DatabricksAccountId = ${databricks_account_id}"
        },
        {
          "sid": "PreventDBFSFromAccessingUnityCatalogMetastore",
          "effect": "Deny",
          "actions": ["s3:*"],
          "principal": "arn:aws:iam::${databricks_aws_account_id}:root",
          "resources": ["${workspace_root_bucket_arn}/unity-catalog/*"]
        }
      ],
      "source_module": "complete-workspace-serverless"
    },
    {
      "policy_name": "workspace-kms-key-policy",
      "description": "KMS key policy for Databricks workspace encryption covering DBFS, managed services, grant management, and optional EBS encryption via cross-account role.",
      "type": "kms-key-policy",
      "statements": [
        {
          "sid": "EnableRootPermissions",
          "effect": "Allow",
          "actions": ["kms:*"],
          "principal": "arn:aws:iam::${aws_account_id}:root",
          "resources": ["*"],
          "purpose": "Allows the AWS account root to manage the KMS key"
        },
        {
          "sid": "AllowDatabricksUseForDBFS",
          "effect": "Allow",
          "actions": [
            "kms:Encrypt",
            "kms:Decrypt",
            "kms:ReEncrypt*",
            "kms:GenerateDataKey*",
            "kms:DescribeKey"
          ],
          "principal": "arn:aws:iam::${databricks_aws_account_id}:root",
          "resources": ["*"],
          "condition": "aws:PrincipalTag/DatabricksAccountId = ${databricks_account_id}",
          "purpose": "Databricks DBFS encryption/decryption"
        },
        {
          "sid": "AllowDatabricksUseForDBFSGrants",
          "effect": "Allow",
          "actions": [
            "kms:CreateGrant",
            "kms:ListGrants",
            "kms:RevokeGrant"
          ],
          "principal": "arn:aws:iam::${databricks_aws_account_id}:root",
          "resources": ["*"],
          "condition": "kms:GrantIsForAWSResource = true AND aws:PrincipalTag/DatabricksAccountId = ${databricks_account_id}",
          "purpose": "KMS grant management for AWS service integrations"
        },
        {
          "sid": "AllowDatabricksUseForManagedServices",
          "effect": "Allow",
          "actions": [
            "kms:Encrypt",
            "kms:Decrypt"
          ],
          "principal": "arn:aws:iam::${databricks_aws_account_id}:root",
          "resources": ["*"],
          "condition": "aws:PrincipalTag/DatabricksAccountId = ${databricks_account_id}",
          "purpose": "Databricks managed services encryption (notebooks, secrets, etc.)"
        },
        {
          "sid": "AllowDatabricksUseForEBS",
          "effect": "Allow",
          "actions": [
            "kms:Decrypt",
            "kms:GenerateDataKey*",
            "kms:CreateGrant",
            "kms:DescribeKey"
          ],
          "principal": "${databricks_cross_account_role_arn} (optional)",
          "resources": ["*"],
          "condition": "kms:ViaService = ec2.*.amazonaws.com",
          "purpose": "EBS volume encryption via cross-account role (only when cross-account role is provided)",
          "notes": "This statement is conditionally included only when databricks_cross_account_role_arn is provided"
        }
      ],
      "source_module": "complete-workspace-serverless"
    }
  ]
}
